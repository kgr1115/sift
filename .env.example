# Copy to .env and fill in your keys. Never commit .env.

# ---------------------------------------------------------------------------
# LLM provider selection
# ---------------------------------------------------------------------------
# Which provider to use at runtime ("anthropic", "openai", "google", "groq").
# You only need the API key for the provider you pick; the others can stay blank.
# The comparison eval auto-detects which keys are set and runs those.
LLM_PROVIDER=anthropic

# Optional explicit model override. Leave blank to use the provider's default.
# Examples per provider:
#   anthropic : claude-sonnet-4-6   (default), claude-haiku-4-5, claude-opus-4-6
#   openai    : gpt-4o-mini         (default), gpt-4o, gpt-4.1, gpt-4.1-mini
#   google    : gemini-2.5-flash    (default), gemini-2.5-flash-lite, gemini-2.5-pro
#   groq      : llama-3.3-70b-versatile (default), llama-3.1-8b-instant
SIFT_MODEL=

# ---------------------------------------------------------------------------
# Provider API keys — fill in whichever you plan to use
# ---------------------------------------------------------------------------
# Anthropic: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini (AI Studio): https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Groq (fast, cheap Llama inference): https://console.groq.com/keys
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# Gmail integration
# ---------------------------------------------------------------------------
# OAuth client credentials JSON downloaded from Google Cloud Console.
# See docs/gmail_setup.md for the setup walkthrough.
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Where to cache the user's Gmail OAuth token after first auth.
GOOGLE_TOKEN_PATH=./token.json

# Path to the local SQLite cache.
SIFT_DB=./sift.db
